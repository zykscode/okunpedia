{
  "name": "okunpedia",
  "author": "Zykson",
  "type": "module",
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:*",
    "build:next": "next build",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true pnpm run build",
    "clean": "rimraf .next out coverage",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "commit": "commit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db-server:file": "pglite-server -p 5435 -m 100 --db=local.db --run \"cmd /c pnpm run db:migrate\"",
    "db-server:memory": "pglite-server -p 5435 -m 100 --run \"cmd /c pnpm run db:migrate\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.4.0",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@logtape/logtape": "^2.1.1",
    "@react-leaflet/core": "^3.0.0",
    "@sentry/nextjs": "^10.55.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/typography": "^0.5.19",
    "@teispace/next-themes": "^0.5.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "github-slugger": "^2.0.0",
    "gsap": "^3.15.0",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.4",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-contentlayer2": "^0.5.8",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "pliny": "^0.4.1",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-leaflet": "^5.0.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.2",
    "rehype-katex": "^7.0.1",
    "rehype-katex-notranslate": "^1.1.4",
    "rehype-preset-minify": "^7.0.1",
    "rehype-prism-plus": "^2.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-math": "^6.0.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.14.3",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/prompt-cli": "^20.5.3",
    "@electric-sql/pglite-socket": "^0.1.6",
    "@faker-js/faker": "^10.4.0",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@spotlightjs/spotlight": "^4.11.4",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "checkly": "^7.14.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.15.0",
    "lefthook": "^2.1.9",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
